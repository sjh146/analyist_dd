# ===========================================
# Example environment configuration
# Copy to .env and replace with actual values
# ===========================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stock_trading
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=your_postgres_password_here

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Proxmox Bridge (Windows VM)
BRIDGE_VM_IP=192.168.1.101
BRIDGE_VM_PORT=6379

# Trading
TRADING_START_HOUR=9
TRADING_END_HOUR=15
MAX_POSITION_SIZE=10000000
MAX_DAILY_TRADE=50000000

# ML
ML_MODEL_VERSION=v1.0
VECTOR_DIMENSION=1024

# DART OpenAPI (Financial Statements & Disclosures)
DART_API_KEY=your_dart_api_key_here

# Bank of Korea ECOS API (Macro-economic indicators)
ECOS_API_KEY=your_ecos_api_key_here

# Data Collection Intervals
MACRO_UPDATE_INTERVAL_HOURS=24
COMPANY_DATA_UPDATE_INTERVAL_DAYS=90

# Feature Engineering
FEATURE_CACHE_TTL_SECONDS=3600
MAX_STOCKS_TO_TRACK=500

# Logging
LOG_LEVEL=INFO
